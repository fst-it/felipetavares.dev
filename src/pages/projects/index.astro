---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../components/astro/BreadcrumbList.astro';
import InlineExpander from '../../components/astro/InlineExpander.astro';
import { contentRepository, siteConfig } from '../../config/site';

const projects = await contentRepository.getProjects();

const statusLabel: Record<string, string> = {
  active: 'Active',
  archived: 'Archived',
  incubating: 'Incubating',
};

const pageTitle = 'Projects';
const pageDescription =
  "Felipe Tavares' projects: deep-dives into systems built to demonstrate hands-on mastery, starting with Selfwright.";
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={`${siteConfig.url}/projects`}>
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: 'Projects', url: `${siteConfig.url}/projects` },
  ]} />
  <section class="relative overflow-hidden px-4 pb-8 pt-12 sm:pt-16" aria-labelledby="projects-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">Projects</p>
      <h1 id="projects-heading" class="text-balance" data-reveal>Proof, not just claims</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        Deep-dives into the systems built to demonstrate hands-on mastery: architecture,
        decisions, and trade-offs, not just a summary line.
      </p>
    </div>
  </section>

  <section class="px-4 pt-11 sm:pt-16 pb-12 sm:pb-16">
    <div class="mx-auto max-w-6xl">
      {
        projects.length > 0 ? (
          <!--
            Value-led narrative cards (H: /projects redesign — owner: "too technical, small letters,
            no value/goals/north stars"). Each card leads with the project's north star, problem, and
            2–3 outcome statements at comfortable reading sizes (≥text-base). Tech stack and build
            metrics collapse behind an InlineExpander ("How it's built") so the executive visitor
            sees value first. The card wrapper is a <div> rather than <a> (HTML requires that
            interactive elements like <details>/<summary> not be nested inside <a>); a clear CTA link
            at the bottom sends the reader to the full deep-dive page.
          -->
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {projects.map((project) => (
              <div
                data-card-motion
                class="glass flex flex-col gap-4 rounded-[var(--radius-md)] p-5"
              >
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <h2 class="font-display text-lg font-semibold text-[var(--text)]">{project.title}</h2>
                  <span class="shrink-0 rounded-full bg-[var(--surface-glass-strong)] px-3 py-1 font-mono text-xs uppercase tracking-wide text-[var(--accent)]">
                    {statusLabel[project.status]}
                  </span>
                </div>

                <p class="text-base font-semibold text-[var(--text)]">{project.northStar}</p>

                <p class="text-base text-muted">{project.problem}</p>

                <ul class="space-y-2">
                  {project.outcomes.map((outcome) => (
                    <li class="flex items-start gap-2 text-base text-[var(--text)]">
                      <span class="mt-1 shrink-0 text-[var(--accent)]" aria-hidden="true">→</span>
                      <span>{outcome}</span>
                    </li>
                  ))}
                </ul>

                <InlineExpander summaryLabel="How it's built" id={`how-built-${project.slug}`}>
                  <div class="space-y-3 pb-1 pt-3">
                    <p class="text-xs text-muted">{project.roleLine}</p>
                    {project.stack.length > 0 && (
                      <ul class="flex flex-wrap gap-1.5">
                        {project.stack.slice(0, 6).map((tech) => (
                          <li class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 text-xs text-muted">
                            {tech}
                          </li>
                        ))}
                        {project.stack.length > 6 && (
                          <li class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 text-xs text-muted">
                            +{project.stack.length - 6}
                          </li>
                        )}
                      </ul>
                    )}
                    {project.metrics.length > 0 && (
                      <ul class="flex flex-wrap gap-1.5">
                        {project.metrics.map((metric) => (
                          <li class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 font-mono text-[11px] font-semibold text-[var(--text)]">
                            {metric.value}
                            <span class="ml-1 font-sans font-normal text-muted">{metric.label}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </InlineExpander>

                <a
                  href={`/projects/${project.slug}`}
                  class="mt-auto text-sm font-medium text-[var(--accent)] hover:underline"
                >
                  Read the deep-dive →
                </a>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-center text-muted">Projects are coming soon.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
