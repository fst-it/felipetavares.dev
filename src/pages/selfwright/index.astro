---
/**
 * /selfwright — Selfwright project landing page.
 *
 * Selfwright is an open-core, local-first career operating system built by this
 * site's owner to run his own career development and interview coaching on it.
 * This page describes what shipped in 0.6.0, how it works, and where to find
 * the public repository.
 *
 * Design: reuses existing site primitives (Section, SectionHeading, glass tiles,
 * gradient-mesh hero, btn-interactive CTA). No new visual language.
 * Content: ground truth from README.md, MANUAL.md §1, SELFWRIGHT-ANCHOR.md §1-4,
 * and CHANGELOG.md — nothing invented.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/astro/Section.astro';
import SectionHeading from '../../components/astro/SectionHeading.astro';
import BreadcrumbList from '../../components/astro/BreadcrumbList.astro';
import SelfwrightMetricsPanel from '../../components/astro/SelfwrightMetricsPanel.astro';
import { siteConfig } from '../../config/site';
import { loadSelfwrightMetrics } from '../../lib/selfwright-metrics';

const pageTitle = 'Selfwright';
const pageDescription =
  'An open-core, local-first career operating system built in public. Every generated claim traces to a locked evidence registry. Truth floor enforced in CI.';
const canonical = `${siteConfig.url}/selfwright`;

// Build-time fetch of the Selfwright repo's published manifest, falling back to a committed
// local snapshot on any failure (network error, timeout, 404, schema mismatch) — see
// src/lib/selfwright-metrics.ts. Never throws, so a manifest hiccup can't break astro build.
const { manifest } = await loadSelfwrightMetrics();

const features = [
  {
    tag: '01',
    title: 'Truth floor, in code',
    body: 'Every cover letter, prep pack, and interview drill traces back to a locked evidence registry (EVD-* ids). 33 fitness checks (28 enforced in CI) validate each artifact before you can use it. You cannot fabricate accidentally or at scale: every claim traces to a locked evidence registry, and any deviation is logged as an audited drift.',
  },
  {
    tag: '02',
    title: 'Deterministic scoring, zero LLM calls',
    body: 'A 7-dimension fit score and ATS parseability report run in milliseconds against your archetypes. No model call, no billing. The scoring math is plain TypeScript, test-covered, and deterministic across runs.',
  },
  {
    tag: '03',
    title: 'Co-piloted generation, no API keys',
    body: 'Selfwright assembles a truth-grounded prompt — evidence selected, archetype framing injected, JD context pulled in — and writes it to a file. You run the output in the Claude session you already have open. A validator checks what comes back. Your existing Claude subscription does the work.',
  },
  {
    tag: '04',
    title: 'Role discovery across 19 providers',
    body: 'Scans Greenhouse, Lever, Ashby, Workday (standard and bot-gated tenants via headless Chromium), SmartRecruiters, BambooHR, Adzuna, Arbeitnow, Oracle Fusion, Recruitee, and a generic JSON feed adapter (with schema.org JSON-LD auto-extraction), plus nine more. Fuzzy-deduplicates by company and title, scores each posting against your archetypes, and writes a prioritised queue. Runs weekly on a scheduled task.',
  },
  {
    tag: '05',
    title: 'Local-first, data stays put',
    body: 'Your truth layer, applications, compensation data, and contacts live in a private git repository on your machine. The data stays local; the only egress is to services you configure yourself, described in the security section below. The data-leak gate fails closed if the boundary is crossed — pre-commit and in CI.',
  },
  {
    tag: '06',
    title: 'Coaching loop that compounds',
    body: 'After each interview: log a debrief, run gap-scan, get a drill. Each round feeds the next. The evidence registry grows. Applications stop starting from scratch.',
  },
];

const trustSignals = [
  { value: manifest.tests.toLocaleString('en-US'), label: 'tests' },
  {
    value: String(manifest.fitnessChecks.total),
    label: `fitness checks (${manifest.fitnessChecks.ci} in CI)`,
  },
  { value: String(manifest.scanProviders), label: 'scan providers' },
  { value: manifest.version, label: 'current release' },
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: 'Selfwright', url: canonical },
  ]} />

  <!-- Hero -->
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="selfwright-heading">
    <div class="gradient-mesh gradient-mesh-hero" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">Open-core · Local-first · {manifest.version}</p>
      <div class="mb-6 flex justify-center">
        <img
          src="/selfwright-logo.png"
          alt="Selfwright logo"
          width="80"
          height="80"
          class="sw-hero-logo rounded-full"
        />
      </div>
      <h1 id="selfwright-heading" class="text-balance" data-reveal>
        A career operating system with a truth floor
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        Job tools optimise keyword volume. Selfwright optimises truthful, defensible output and
        compounds everything you learn about companies, roles, and your own evidence into a
        private knowledge base.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="https://github.com/fst-it/Selfwright"
          class="relative rounded-[var(--radius-sm)] bg-[var(--accent)] accent-bg-image px-6 py-3 font-semibold text-[var(--accent-contrast)] btn-interactive"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
        </a>
        <a
          href="#how-it-works"
          class="glass rounded-[var(--radius-sm)] px-6 py-3 font-semibold text-[var(--text)] btn-interactive"
        >
          How it works
        </a>
      </div>
    </div>
  </section>

  <!-- Trust signals -->
  <Section padding="first" aria-labelledby="trust-heading">
    <h2 id="trust-heading" class="sr-only">Platform metrics</h2>
    <div class="grid auto-rows-fr grid-cols-2 gap-4 sm:grid-cols-4">
      {trustSignals.map((s, i) => (
        <div
          data-card-motion
          class="sw-trust-tile tile-glow glass flex flex-col rounded-[var(--radius-md)] p-6 text-center"
          style={`--tile-index: ${i}`}
        >
          <p class="font-mono text-2xl font-bold text-[var(--accent)]">{s.value}</p>
          <p class="mt-2 text-xs text-muted">{s.label}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Measured metrics panel (moved from /projects/selfwright) -->
  <Section aria-label="Measured, not claimed">
    <SelfwrightMetricsPanel />
  </Section>

  <!-- Why the truth floor is the moat -->
  <Section aria-labelledby="why-heading">
    <SectionHeading
      eyebrow="The bet"
      title="Keyword density gets you past an ATS screen"
      subtitle="It does not hold up in a second conversation with the same company, or when an interviewer probes the specific claim on the page. Selfwright starts from the opposite position."
    />
    <div class="mt-8 max-w-3xl">
      <p class="text-muted">
        The enforcing mechanism is the truth floor. Every cover letter, prep pack, research
        document, and interview drill traces back to a locked evidence registry. The co-pilot
        path assembles a grounded prompt and stops. A validator checks what comes back before
        you can use it. The honesty-wall system flags retired phrases. Drifts — the only
        sanctioned exception — are scored, ledgered, and confidence-banded before they touch
        any output.
      </p>
      <p class="mt-4 text-muted">
        The secondary payoff: every interview, debrief, and drill feeds the same evidence base.
        Your next application benefits from the last one.
      </p>
    </div>
  </Section>

  <!-- Features -->
  <Section id="how-it-works" aria-labelledby="features-heading">
    <h2 id="features-heading" class="sr-only">How it works</h2>
    <SectionHeading
      eyebrow="What it does"
      title="Six capabilities, one evidence registry"
    />
    <ul class="mt-10 grid auto-rows-fr grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f, i) => (
        <li
          data-card-motion
          class="sw-feature-tile tile-glow glass flex h-full flex-col rounded-[var(--radius-md)] p-6"
          style={`--tile-index: ${i}`}
        >
          <p class="font-mono text-xs uppercase tracking-wider text-[var(--accent)]">{f.tag}</p>
          <span class="sw-tile-underline mt-2" aria-hidden="true" />
          <h3 class="mt-4 font-display text-base font-semibold text-[var(--text)]">{f.title}</h3>
          <p class="mt-3 text-sm text-muted">{f.body}</p>
        </li>
      ))}
    </ul>
  </Section>

  <!-- Architecture note -->
  <Section aria-labelledby="architecture-heading">
    <SectionHeading
      eyebrow="Architecture"
      title="TypeScript-first, hexagonal, tested"
    />
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {[
        {
          label: 'Stack',
          detail: 'TypeScript strict, Vitest, Hono web server, Zod schemas, pnpm workspaces. The domain core is pure TypeScript with zero framework imports — enforced by a fitness function in CI.',
        },
        {
          label: 'Storage',
          detail: 'Git markdown/YAML is the source of truth. PostgreSQL + pgvector is a rebuildable projection. Droppable anytime without data loss.',
        },
        {
          label: 'Generation',
          detail: 'No API key required. The default path assembles a prompt and hands it to the Claude session you already have open. An optional headless adapter exists for scripted use.',
        },
        {
          label: 'Security',
          detail: 'Named-entity data-leak gate derived from your private data at commit time. SSRF allowlists on every outbound call. CSRF synchronizer tokens on all write routes. Loopback-only web binding.',
        },
      ].map((item) => (
        <div class="tile-glow glass rounded-[var(--radius-md)] p-5">
          <p class="font-mono text-sm font-semibold text-[var(--text)]">{item.label}</p>
          <p class="mt-2 text-sm text-muted">{item.detail}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Harness + platform support -->
  <Section aria-labelledby="platform-heading">
    <SectionHeading
      eyebrow="Where it runs"
      title="Any MCP-capable agent, plus a CLI"
    />
    <div class="mt-8 max-w-3xl">
      <p class="text-muted">
        The skills run in Claude Code, Cursor, and OpenCode — any agent that speaks MCP. Claude
        Code is the primary target and gets the most testing; Cursor and OpenCode work but see
        less daily use. A standalone CLI runs the same commands with no agent in the loop.
      </p>
      <p class="mt-4 text-muted">
        The TypeScript core has no OS-specific code, so macOS, Linux, and Windows should all
        work. Day-to-day use has been on Windows, so that's the only platform verified end to
        end. Weekly automated scanning currently runs on Windows Task Scheduler; cron and
        launchd support for Linux and macOS are planned, not shipped.
      </p>
    </div>
  </Section>

  <!-- Security / no-telemetry -->
  <Section aria-labelledby="security-heading">
    <SectionHeading
      eyebrow="Privacy"
      title="No telemetry. Ever."
    />
    <div class="mt-8 max-w-3xl">
      <p class="text-muted">
        A security audit confirmed zero analytics, zero phone-home, zero data sent to the
        maintainer or any vendor. Your career data — evidence registry, applications,
        compensation figures, contacts — stays in your private git repository on your machine.
      </p>
      <p class="mt-4 text-muted">
        The only outbound traffic is to services you configure yourself:
      </p>
      <ul class="mt-3 space-y-2 text-muted">
        <li class="flex gap-3">
          <span class="mt-0.5 font-mono text-xs text-[var(--accent)] shrink-0">→</span>
          <span>Job boards receive search terms only — no personal data, no stored session.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-0.5 font-mono text-xs text-[var(--accent)] shrink-0">→</span>
          <span>The model gateway is opt-in and off by default. When you enable it, prompts go to the provider you choose — same as running Claude yourself.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-0.5 font-mono text-xs text-[var(--accent)] shrink-0">→</span>
          <span>Push notifications go to your own ntfy topic with job IDs only, never PII.</span>
        </li>
      </ul>
      <p class="mt-4 text-muted">
        The data-leak gate enforces this boundary on every commit and in CI — it fails closed,
        not open.
      </p>
    </div>
  </Section>

  <!-- How this compares -->
  <Section aria-labelledby="compares-heading">
    <SectionHeading
      eyebrow="Context"
      title="How this compares to career-ops tools"
    />
    <div class="mt-8 max-w-3xl">
      <p class="text-muted">
        Selfwright shares ground with other career-ops tools: local-first, zero telemetry, human-in-the-loop on every generated output. Three architectural choices set it apart: the truth floor is enforced in code (every artifact traces to a locked evidence registry; deviations log as audited drift); port boundaries are fitness-function-checked (the build fails if domain code touches infrastructure directly); the generation path needs no API key and no per-call billing.
      </p>
      <p class="mt-4 text-muted">
        The full breakdown is in the <a href="https://github.com/fst-it/Selfwright/blob/main/docs/comparison-career-ops.md" class="text-[var(--accent)] underline underline-offset-2" target="_blank" rel="noopener noreferrer">comparison doc in the Selfwright repo</a>.
      </p>
    </div>
  </Section>

  <!-- Built in public -->
  <Section aria-labelledby="built-in-public-heading">
    <div class="border-beam glass rounded-[var(--radius-lg)] p-10 sm:p-16">
      <SectionHeading
        eyebrow="Built in public"
        title="Used for my own career development"
      />
      <p class="mt-4 max-w-2xl text-muted">
        Selfwright is the tool I built and run on real career data. The scanner queries live ATS boards. The fit scorer grades real job descriptions against my archetypes. After each interview, the coaching loop — debriefs, gap-scans, drills — feeds an evidence base that compounds. The data-leak gate has caught real mistakes.
      </p>
      <p class="mt-4 max-w-2xl text-muted">
        The framework is Apache 2.0. Your truth layer stays on your machine. The evidence
        registry, applications, and contacts never leave your private git repository.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="https://github.com/fst-it/Selfwright"
          class="relative rounded-[var(--radius-sm)] bg-[var(--accent)] accent-bg-image px-6 py-3 font-semibold text-[var(--accent-contrast)] btn-interactive"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
        </a>
        <a
          href={`${siteConfig.url}/contact`}
          class="glass rounded-[var(--radius-sm)] px-6 py-3 font-semibold text-[var(--text)] btn-interactive"
        >
          Get in touch
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .sw-hero-logo {
    box-shadow: 0 0 24px 0 var(--accent-glow);
  }

  .sw-tile-underline {
    display: block;
    width: 2rem;
    height: 2px;
    border-radius: 2px;
    background: var(--accent);
    box-shadow: 0 0 6px 0 var(--accent-glow);
  }

  /* Non-interactive glow-on-hover — same treatment as CredibilityCta.astro's .tile-glow */
  .tile-glow {
    transition: box-shadow var(--duration-micro, 200ms) var(--ease-out, ease-out);
  }

  @media (hover: hover) {
    .tile-glow:hover {
      box-shadow: 0 4px 20px -6px var(--accent-glow);
    }
  }

  /* Staggered reveal-on-scroll — same pattern as CredibilityCta.astro/SelfwrightMetricsPanel.astro */
  .sw-feature-tile,
  .sw-trust-tile {
    opacity: 1;
  }

  @supports (animation-timeline: view()) {
    .sw-feature-tile,
    .sw-trust-tile {
      animation: sw-tile-reveal linear both;
      animation-timeline: view();
      animation-range: entry 0% cover 25%;
      animation-delay: calc(var(--tile-index, 0) * 80ms);
    }
  }

  @supports not (animation-timeline: view()) {
    .sw-feature-tile,
    .sw-trust-tile {
      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity var(--duration-reveal) var(--ease-out),
        transform var(--duration-reveal) var(--ease-out);
      transition-delay: calc(var(--tile-index, 0) * 80ms);
    }

    .sw-feature-tile.is-visible,
    .sw-trust-tile.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes sw-tile-reveal {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sw-feature-tile,
    .sw-trust-tile {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  html[data-motion='off'] .sw-feature-tile,
  html[data-motion='off'] .sw-trust-tile {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
</style>

<script>
  // IntersectionObserver fallback — same pattern as CredibilityCta.astro/SelfwrightMetricsPanel.astro
  const tiles = Array.from(document.querySelectorAll<HTMLElement>('.sw-feature-tile, .sw-trust-tile'));
  if ('IntersectionObserver' in window && tiles.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      },
      { threshold: 0.2 }
    );
    tiles.forEach((tile) => observer.observe(tile));
  } else {
    tiles.forEach((tile) => tile.classList.add('is-visible'));
  }
</script>
