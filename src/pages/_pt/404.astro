---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config/site';
import { getStrings } from '../../i18n';

const strings = getStrings('pt-br');
const pageTitle = strings.notFound.title;
---

<BaseLayout title={pageTitle} description={strings.notFound.description} canonical={`${siteConfig.url}/pt/404`} alternatePath="/404">
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="notfound-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-2xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">404</p>
      <h1 id="notfound-heading" class="text-balance" data-reveal>{strings.notFound.title}</h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-muted">{strings.notFound.description}</p>

      <div class="mt-10 flex justify-center">
        <a
          href="/pt/"
          class="border-beam rounded-[var(--radius-sm)] bg-[var(--accent)] px-6 py-3 text-center font-semibold text-[var(--accent-contrast)] btn-interactive"
        >
          {strings.notFound.backHome}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
