---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../../components/astro/BreadcrumbList.astro';
import { siteConfig } from '../../../config/site';
import { getStrings } from '../../../i18n';

const strings = getStrings('pt-br');
const pageTitle = strings.accessibilityPage.eyebrow;
const pageDescription =
  'A declaração de acessibilidade de Felipe Tavares: padrão WCAG 2.1 AA, controles no site para movimento, contraste e tamanho de texto, e como relatar um problema.';
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={`${siteConfig.url}/pt/accessibility`} alternatePath="/accessibility">
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: strings.accessibilityPage.eyebrow, url: `${siteConfig.url}/pt/accessibility` },
  ]} />
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="a11y-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">{strings.accessibilityPage.eyebrow}</p>
      <h1 id="a11y-heading" class="text-balance" data-reveal>{strings.accessibilityPage.heading}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        {strings.accessibilityPage.subtitle}
      </p>
    </div>
  </section>

  <section class="px-4 pb-11 sm:pb-16">
    <div class="mx-auto flex max-w-3xl flex-col gap-6">
      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">{strings.accessibilityPage.standardHeading}</h2>
        <p class="mt-3 text-muted">
          {strings.accessibilityPage.standardBody}
        </p>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">{strings.accessibilityPage.controlsHeading}</h2>
        <p class="mt-3 text-muted">
          {strings.accessibilityPage.controlsIntro}
        </p>
        <ul class="mt-4 flex flex-col gap-3">
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">{strings.a11yPanel.reduceMotionLabel}</p>
            <p class="mt-1 text-sm text-muted">
              {strings.a11yPanel.reduceMotionDescription}
            </p>
          </li>
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">{strings.a11yPanel.highContrastLabel}</p>
            <p class="mt-1 text-sm text-muted">
              {strings.a11yPanel.highContrastDescription}
            </p>
          </li>
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">{strings.a11yPanel.largerTextLabel}</p>
            <p class="mt-1 text-sm text-muted">
              {strings.a11yPanel.largerTextDescription}
            </p>
          </li>
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">{strings.a11yPanel.visualEffectsLabel}</p>
            <p class="mt-1 text-sm text-muted">
              {strings.a11yPanel.visualEffectsDescription}
            </p>
          </li>
        </ul>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">{strings.accessibilityPage.limitationsHeading}</h2>
        <p class="mt-3 text-muted">
          {strings.accessibilityPage.limitationsBody}
        </p>
      </div>

      <div class="border-beam glass rounded-[var(--radius-lg)] p-8 text-center">
        <h2 class="font-display text-xl font-semibold">{strings.accessibilityPage.reportHeading}</h2>
        <p class="mx-auto mt-3 max-w-xl text-muted">
          {strings.accessibilityPage.reportBody}
        </p>
        <a
          href="/pt/contact"
          class="border-beam mt-6 inline-block rounded-[var(--radius-sm)] bg-[var(--accent)] px-6 py-3 text-center font-semibold text-[var(--accent-contrast)] btn-interactive"
        >
          {strings.accessibilityPage.contactCta}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
