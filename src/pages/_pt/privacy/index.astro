---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../../components/astro/BreadcrumbList.astro';
import { siteConfig } from '../../../config/site';
import { getStrings } from '../../../i18n';

const strings = getStrings('pt-br');
const pageTitle = strings.privacyPage.eyebrow;
const pageDescription =
  'A declaração de privacidade de Felipe Tavares: sem cookies, sem pixels de rastreamento, sem banner de consentimento por design. O que o armazenamento local faz, o que os dados do formulário de contato tocam, e o Cloudflare Web Analytics.';

const analyticsEnabled = Boolean(siteConfig.cfAnalyticsToken);
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={`${siteConfig.url}/pt/privacy`} alternatePath="/privacy">
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: strings.privacyPage.eyebrow, url: `${siteConfig.url}/pt/privacy` },
  ]} />
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="privacy-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">{strings.privacyPage.eyebrow}</p>
      <h1 id="privacy-heading" class="text-balance" data-reveal>{strings.privacyPage.heading}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        {strings.privacyPage.subtitle}
      </p>
    </div>
  </section>

  <section class="px-4 pb-11 sm:pb-16">
    <div class="mx-auto flex max-w-3xl flex-col gap-6">
      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">{strings.privacyPage.noTrackingHeading}</h2>
        <p class="mt-3 text-muted">
          {strings.privacyPage.noTrackingBody}
        </p>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">{strings.privacyPage.localStorageHeading}</h2>
        <p class="mt-3 text-muted">
          {strings.privacyPage.localStorageIntro}
        </p>
        <ul class="mt-4 flex flex-col gap-3">
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">{strings.privacyPage.localStorageThemeLabel}</p>
            <p class="mt-1 text-sm text-muted">{strings.privacyPage.localStorageThemeBody}</p>
          </li>
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">{strings.privacyPage.localStorageA11yLabel}</p>
            <p class="mt-1 text-sm text-muted">
              {strings.privacyPage.localStorageA11yBodyPrefix}{' '}
              <a href="/pt/accessibility" class="text-[var(--accent)] underline underline-offset-2">/pt/accessibility</a>).
            </p>
          </li>
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">{strings.privacyPage.localStorageChatLabel}</p>
            <p class="mt-1 text-sm text-muted">
              {strings.privacyPage.localStorageChatBody}
            </p>
          </li>
        </ul>
        <p class="mt-4 text-sm text-muted">
          {strings.privacyPage.localStorageOutro}
        </p>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">{strings.privacyPage.contactFormHeading}</h2>
        <p class="mt-3 text-muted">
          {strings.privacyPage.contactFormBody}
        </p>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">{strings.privacyPage.analyticsHeading}</h2>
        {
          analyticsEnabled ? (
            <p class="mt-3 text-muted">
              {strings.privacyPage.analyticsEnabledBody}
            </p>
          ) : (
            <p class="mt-3 text-muted">
              {strings.privacyPage.analyticsDisabledBody}
            </p>
          )
        }
      </div>

      <div class="border-beam glass rounded-[var(--radius-lg)] p-8 text-center">
        <h2 class="font-display text-xl font-semibold">{strings.privacyPage.questionsHeading}</h2>
        <p class="mx-auto mt-3 max-w-xl text-muted">
          {strings.privacyPage.questionsBody}
        </p>
        <a
          href="/pt/contact"
          class="border-beam mt-6 inline-block rounded-[var(--radius-sm)] bg-[var(--accent)] px-6 py-3 text-center font-semibold text-[var(--accent-contrast)] btn-interactive"
        >
          {strings.privacyPage.contactCta}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
