---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../../components/astro/BreadcrumbList.astro';
import InlineExpander from '../../../components/astro/InlineExpander.astro';
import { contentRepository, siteConfig } from '../../../config/site';
import { getStrings } from '../../../i18n';

const strings = getStrings('pt-br');
const projects = await contentRepository.getProjects();

const statusLabel: Record<string, string> = {
  active: strings.home.statusActive,
  archived: strings.home.statusArchived,
  incubating: strings.home.statusIncubating,
};

const pageTitle = strings.projectsPage.eyebrow;
const pageDescription =
  'Os projetos de Felipe Tavares: aprofundamentos em sistemas construídos para demonstrar domínio prático, começando pelo Selfwright.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteConfig.url}/pt/projects`}
  markdownTwin="/pt/projects/index.md"
  alternatePath="/projects"
>
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: strings.projectsPage.eyebrow, url: `${siteConfig.url}/pt/projects` },
  ]} />
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="projects-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">{strings.projectsPage.eyebrow}</p>
      <h1 id="projects-heading" class="text-balance" data-reveal>{strings.projectsPage.heading}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        {strings.projectsPage.subtitle}
      </p>
    </div>
  </section>

  <!-- Project deep-dives stay EN-only in v1 (V3d addendum) — cards link to the unprefixed EN
       project page and carry an "em inglês" badge; only this page's own chrome is PT.

       Value-led narrative cards (H: /projects redesign): northStar, problem, outcomes at
       comfortable sizes (≥text-base); tech stack and metrics collapse behind InlineExpander
       (same pattern as EN /projects). Card wrapper is a <div> to allow the <details> disclosure;
       the CTA link at the bottom navigates to the EN deep-dive.

       The 320px horizontal-overflow fix from V5a is preserved: the title+badges header row uses
       `flex-wrap` so the "em inglês" badge and status pill wrap on narrow viewports. -->
  <section class="px-4 pt-11 sm:pt-16 pb-11 sm:pb-16">
    <div class="mx-auto max-w-6xl">
      {
        projects.length > 0 ? (
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {projects.map((project) => (
              <div
                data-card-motion
                class="glass flex flex-col gap-4 rounded-[var(--radius-md)] p-5"
              >
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <h2 class="font-display text-lg font-semibold text-[var(--text)]">{project.title}</h2>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full bg-[var(--surface-glass-strong)] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-muted">
                      {strings.home.inEnglishBadge}
                    </span>
                    <span class="rounded-full bg-[var(--surface-glass-strong)] px-3 py-1 font-mono text-xs uppercase tracking-wide text-[var(--accent)]">
                      {statusLabel[project.status]}
                    </span>
                  </div>
                </div>

                <p class="text-base font-semibold text-[var(--text)]">{project.northStar}</p>

                <p class="text-base text-muted">{project.problem}</p>

                <ul class="space-y-2">
                  {project.outcomes.map((outcome) => (
                    <li class="flex items-start gap-2 text-base text-[var(--text)]">
                      <span class="mt-1 shrink-0 text-[var(--accent)]" aria-hidden="true">→</span>
                      <span>{outcome}</span>
                    </li>
                  ))}
                </ul>

                <InlineExpander summaryLabel={strings.projectsPage.howItsBuilt} id={`how-built-pt-${project.slug}`}>
                  <div class="space-y-3 pb-1 pt-3">
                    <p class="text-xs text-muted">{project.roleLine}</p>
                    {project.stack.length > 0 && (
                      <ul class="flex flex-wrap gap-1.5">
                        {project.stack.slice(0, 6).map((tech) => (
                          <li class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 text-xs text-muted">
                            {tech}
                          </li>
                        ))}
                        {project.stack.length > 6 && (
                          <li class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 text-xs text-muted">
                            +{project.stack.length - 6}
                          </li>
                        )}
                      </ul>
                    )}
                    {project.metrics.length > 0 && (
                      <ul class="flex flex-wrap gap-1.5">
                        {project.metrics.map((metric) => (
                          <li class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 font-mono text-[11px] font-semibold text-[var(--text)]">
                            {metric.value}
                            <span class="ml-1 font-sans font-normal text-muted">{metric.label}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </InlineExpander>

                <a
                  href={`/projects/${project.slug}`}
                  class="mt-auto text-sm font-medium text-[var(--accent)] hover:underline"
                >
                  {strings.home.readDeepDive}
                </a>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-center text-muted">{strings.projectsPage.empty}</p>
        )
      }
    </div>
  </section>
</BaseLayout>
