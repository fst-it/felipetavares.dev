---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../../components/astro/BreadcrumbList.astro';
import { contentRepository, siteConfig } from '../../../config/site';
import { getStrings } from '../../../i18n';
import { slugifyTag } from '../../../lib/slugify-tag';
import { formatCardDate } from '../../../lib/format-date';
import { VERDICT_LABELS } from '../../../core/entities/reading';

const strings = getStrings('pt-br');
const s = strings.readingPage;
const articles = await contentRepository.getArticles();
// Mirror EN /writing: the first article is the "featured" entry; exclude it from the
// chronological grid so it doesn't appear twice (once as the featured card on EN, once again
// in the flat list here on PT). PT has no featured-card treatment of its own — the grid just
// starts from the second article. If there are no articles beyond the first, the grid is empty.
const [, ...rest] = articles;

const allTags = [...new Set(articles.flatMap((a) => a.tags))].sort();

// Recently reviewed strip — renders NOTHING when there are zero reviews (no empty shell).
const recentReadings = await contentRepository.getReadings();
const recentlyReviewed = recentReadings.slice(0, 3);

const pageTitle = strings.writingPage.eyebrow;
const pageDescription =
  'Artigos e papers de Felipe Tavares sobre arquitetura corporativa, estratégia de IA, plataformas de dados e liderança em uma estrutura matricial global.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteConfig.url}/pt/writing`}
  markdownTwin="/pt/writing/index.md"
  alternatePath="/writing"
>
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: strings.writingPage.eyebrow, url: `${siteConfig.url}/pt/writing` },
  ]} />
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="writing-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">{strings.writingPage.eyebrow}</p>
      <h1 id="writing-heading" class="text-balance" data-reveal>{strings.writingPage.heading}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        {strings.writingPage.subtitle}
      </p>
    </div>
  </section>

  <!-- Articles stay EN-only in v1 (V3d addendum) — cards link to the unprefixed EN article page and
       carry an "em inglês" badge; tag links point at the unprefixed EN tag pages; only this page's
       own chrome is PT. -->
  <section class="px-4 pt-11 sm:pt-16 pb-11 sm:pb-16">
    <div class="mx-auto max-w-6xl">
      {
        rest.length > 0 ? (
          <>
            {allTags.length > 0 && (
              <div class="mb-8" aria-label="Filtrar por tag">
                <p class="mb-1 font-mono text-xs uppercase tracking-wider text-[var(--accent)]">{strings.writingPage.browseByTheme}</p>
                <p class="mb-4 text-sm text-muted">{strings.writingPage.browseByThemeSubtitle}</p>
                <div class="flex flex-wrap gap-2">
                  {allTags.map((tag) => (
                    <a
                      href={`/writing/tags/${slugifyTag(tag)}`}
                      class="inline-flex min-h-11 items-center rounded-full bg-[var(--surface-glass-strong)] px-4 py-2 text-xs font-medium text-muted transition-colors duration-200 hover:text-[var(--accent)]"
                    >
                      {tag}
                    </a>
                  ))}
                </div>
              </div>
            )}

            <div class="grid auto-rows-fr grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {rest.map((article) => (
                <a
                  href={`/writing/${article.slug}`}
                  data-card-motion
                  class="glass group flex h-full flex-col justify-between rounded-[var(--radius-md)] p-6 transition-transform duration-200 hover:-translate-y-1"
                >
                  <div>
                    <div class="flex items-center justify-between gap-2">
                      <h2 class="font-display text-lg font-semibold text-[var(--text)]">{article.title}</h2>
                      <span class="shrink-0 rounded-full bg-[var(--surface-glass-strong)] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-muted">
                        {strings.home.inEnglishBadge}
                      </span>
                    </div>
                    <p class="mt-2 text-sm text-muted">{article.description}</p>
                  </div>
                  <div class="mt-6 flex flex-wrap items-center gap-2 font-mono text-xs text-muted">
                    <span>{formatCardDate(article.pubDate, 'pt-br')}</span>
                    <span aria-hidden="true">·</span>
                    <span>{article.readingTime}</span>
                  </div>
                </a>
              ))}
            </div>
          </>
        ) : (
          <p class="text-center text-muted">{strings.writingPage.empty}</p>
        )
      }
    </div>
  </section>
  {/* Recently reviewed strip — omitted entirely when no reviews exist (no empty shell). */}
  {recentlyReviewed.length > 0 && (
    <section class="px-4 pb-11 sm:pb-16" aria-labelledby="recently-reviewed-heading">
      <div class="mx-auto max-w-6xl">
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 id="recently-reviewed-heading" class="font-display text-xl font-semibold text-[var(--text)]">
            {s.recentlyReviewed}
          </h2>
          <a href="/reading" class="text-sm font-medium text-[var(--accent)] hover:underline">
            All reviews →
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentlyReviewed.map((r) => (
            <a
              href="/reading"
              data-card-motion
              class="glass flex flex-col gap-3 rounded-[var(--radius-md)] p-5 transition-transform duration-200 hover:-translate-y-1"
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 font-mono text-[10px] uppercase tracking-wide text-muted">
                  {r.type}
                </span>
                <span
                  class="rounded-full px-2.5 py-1 font-mono text-[10px] uppercase tracking-wide"
                  data-verdict={r.verdict}
                  style="background: var(--surface-glass-strong);"
                >
                  {VERDICT_LABELS[r.verdict].pt}
                </span>
              </div>
              <div>
                <h3 class="font-display text-base font-semibold text-[var(--text)]">{r.title}</h3>
                <p class="text-sm text-muted">{r.author}</p>
              </div>
              <p class="text-sm text-[var(--text)]">{r.verdictLine}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  [data-verdict='foundational'] { color: var(--accent); }
  [data-verdict='worth-your-hours'] { color: var(--success); }
  [data-verdict='situational'] { color: var(--warn); }
  [data-verdict='skip-unless'] { color: var(--text-muted); }
</style>
