---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../../components/astro/BreadcrumbList.astro';
import { contentRepository, siteConfig } from '../../../config/site';
import { getStrings } from '../../../i18n';

const strings = getStrings('pt-br');
const talks = await contentRepository.getTalks();

const buildTime = new Date();
const dateFormatter = new Intl.DateTimeFormat('pt-BR', { month: 'short', year: 'numeric' });
const dateFormatterFull = new Intl.DateTimeFormat('pt-BR', { month: 'short', day: 'numeric', year: 'numeric' });

function isUpcoming(value: string): boolean {
  const parsed = new Date(value);
  return !Number.isNaN(parsed.getTime()) && parsed > buildTime;
}

function formatDate(value: string): string {
  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? value : dateFormatter.format(parsed);
}

function formatDateFull(value: string): string {
  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? value : dateFormatterFull.format(parsed);
}

const pageTitle = strings.speakingPage.eyebrow;
const pageDescription =
  'Palestras, painéis, artigos, podcasts e imprensa com Felipe Tavares sobre arquitetura corporativa, IA e estratégia de dados.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteConfig.url}/pt/speaking`}
  markdownTwin="/pt/speaking/index.md"
  alternatePath="/speaking"
>
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: strings.speakingPage.eyebrow, url: `${siteConfig.url}/pt/speaking` },
  ]} />
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="speaking-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">{strings.speakingPage.eyebrow}</p>
      <h1 id="speaking-heading" class="text-balance" data-reveal>{strings.speakingPage.heading}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        {strings.speakingPage.subtitle}
      </p>
    </div>
  </section>

  <section class="px-4 pt-11 sm:pt-16 pb-11 sm:pb-16" aria-labelledby="talks-heading">
    <h2 id="talks-heading" class="sr-only">{strings.speakingPage.talksHeading}</h2>
    <div class="mx-auto max-w-3xl">
      {
        talks.length > 0 ? (
          <ol class="flex flex-col gap-4">
            {talks.map((talk) => {
              const upcoming = isUpcoming(talk.date);
              return (
              <li class="glass rounded-[var(--radius-md)] p-6">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full bg-[var(--surface-glass-strong)] px-3 py-1 font-mono text-xs uppercase tracking-wide text-[var(--accent)]">
                    {strings.speakingPage.typeLabels[talk.type] ?? talk.type}
                  </span>
                  {upcoming && (
                    <span class="rounded-full bg-[var(--accent)] px-3 py-1 font-mono text-xs uppercase tracking-wide text-[var(--accent-contrast)]">
                      {strings.speakingPage.upcoming}
                    </span>
                  )}
                  <span class="font-mono text-xs text-muted">{upcoming ? formatDateFull(talk.date) : formatDate(talk.date)}</span>
                </div>
                <h3 class="mt-3 font-display text-lg font-semibold text-[var(--text)]">
                  {talk.url ? (
                    <a href={talk.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--accent)]">
                      {talk.title}
                    </a>
                  ) : (
                    talk.title
                  )}
                </h3>
                <p class="mt-1 text-sm text-muted">{talk.event}</p>
                <p class="mt-2 text-sm text-muted">{talk.abstract}</p>
                {talk.slidesUrl && (
                  <a
                    href={talk.slidesUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-3 inline-block text-sm font-medium text-[var(--accent)] underline underline-offset-2"
                  >
                    {strings.speakingPage.viewSlides}
                  </a>
                )}
              </li>
              );
            })}
          </ol>
        ) : (
          <div class="glass rounded-[var(--radius-md)] p-10 text-center">
            <p class="text-muted">{strings.speakingPage.empty}</p>
          </div>
        )
      }
    </div>

    <div class="border-beam glass mx-auto mt-12 max-w-3xl rounded-[var(--radius-lg)] p-8 text-center sm:p-12">
      <h2 class="font-display text-xl">{strings.speakingPage.inviteHeading}</h2>
      <p class="mx-auto mt-3 max-w-xl text-muted">
        {strings.speakingPage.inviteBody}
      </p>
      <a
        href="/pt/contact"
        class="border-beam mt-6 inline-block rounded-[var(--radius-sm)] bg-[var(--accent)] px-6 py-3 text-center font-semibold text-[var(--accent-contrast)] btn-interactive"
      >
        {strings.speakingPage.inviteCta}
      </a>
    </div>
  </section>
</BaseLayout>
