---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../components/astro/BreadcrumbList.astro';
import { siteConfig } from '../../config/site';

const pageTitle = 'Privacy';
const pageDescription =
  "Felipe Tavares' privacy statement: no cookies, no tracking pixels, no consent banner by design. What local storage is used for, what contact-form data touches, and Cloudflare Web Analytics.";

const analyticsEnabled = Boolean(siteConfig.cfAnalyticsToken);
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={`${siteConfig.url}/privacy`}>
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: 'Privacy', url: `${siteConfig.url}/privacy` },
  ]} />
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="privacy-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">Privacy</p>
      <h1 id="privacy-heading" class="text-balance" data-reveal>Nothing to opt out of</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        This site doesn't track you. No cookies, no tracking pixels, no consent banner: by design, not by omission.
      </p>
    </div>
  </section>

  <section class="px-4 pb-11 sm:pb-16">
    <div class="mx-auto flex max-w-3xl flex-col gap-6">
      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">No cookies, no tracking, no consent banner</h2>
        <p class="mt-3 text-muted">
          This site sets no cookies and embeds no third-party tracking pixels. There is nothing
          here that requires a cookie-consent banner, because there is nothing here to consent to.
          That is not a compliance workaround. It's the actual architecture: a static site with no ad network, no session tracking, and no cross-site identifiers.
        </p>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">What local storage is used for</h2>
        <p class="mt-3 text-muted">
          A handful of preferences are saved in your browser's own local/session storage, never sent to any server, never leaving this device:
        </p>
        <ul class="mt-4 flex flex-col gap-3">
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">Theme</p>
            <p class="mt-1 text-sm text-muted">Whether you're viewing the site in dark or light mode.</p>
          </li>
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">Motion, contrast, and text size</p>
            <p class="mt-1 text-sm text-muted">
              The accessibility panel's reduce-motion, high-contrast, larger-text, and
              visual-effects preferences (see <a href="/accessibility" class="text-[var(--accent)] underline underline-offset-2">/accessibility</a>).
            </p>
          </li>
          <li class="rounded-[var(--radius-sm)] bg-[var(--surface-glass-strong)] p-4">
            <p class="font-medium text-[var(--text)]">Chat session</p>
            <p class="mt-1 text-sm text-muted">
              The message history for "Ask Felipe's AI," kept only for the current browser tab
              session so a page refresh doesn't lose the conversation.
            </p>
          </li>
        </ul>
        <p class="mt-4 text-sm text-muted">
          None of this is a cookie, none of it is sent anywhere, and clearing your browser's site
          data removes it completely.
        </p>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">Contact-form data</h2>
        <p class="mt-3 text-muted">
          Submitting the contact form sends your message directly to email delivery. Nothing is stored in a database, added to a mailing list, or shared with a third party beyond the transactional email provider used to deliver it.
        </p>
      </div>

      <div class="glass rounded-[var(--radius-lg)] p-8">
        <h2 class="font-display text-xl font-semibold">Analytics</h2>
        {
          analyticsEnabled ? (
            <p class="mt-3 text-muted">
              This site uses <a href="https://www.cloudflare.com/web-analytics/" class="text-[var(--accent)] underline underline-offset-2" target="_blank" rel="noopener noreferrer">Cloudflare Web Analytics</a>,
              a cookieless, privacy-first analytics beacon that doesn't use any client-side state,
              doesn't track individuals across sites, and doesn't require a consent banner. It
              measures aggregate page views only.
            </p>
          ) : (
            <p class="mt-3 text-muted">
              Cloudflare Web Analytics, a cookieless, privacy-first analytics beacon, will be
              enabled at launch. It doesn't use any client-side state, doesn't track individuals
              across sites, and doesn't require a consent banner, consistent with everything else
              on this page.
            </p>
          )
        }
      </div>

      <div class="border-beam glass rounded-[var(--radius-lg)] p-8 text-center">
        <h2 class="font-display text-xl font-semibold">Questions</h2>
        <p class="mx-auto mt-3 max-w-xl text-muted">
          If anything here is unclear, reach out directly.
        </p>
        <a
          href="/contact"
          class="border-beam mt-6 inline-block rounded-[var(--radius-sm)] bg-[var(--accent)] px-6 py-3 text-center font-semibold text-[var(--accent-contrast)] btn-interactive"
        >
          Contact
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
