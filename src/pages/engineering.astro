---
/**
 * Proof-of-work engineering hub (V3 refinement follow-on). EN-only — see the `engineering`
 * collection's comment in content.config.ts for why there's no PT sibling. Reuses the site's
 * existing Section/SectionHeading/DetailSheet primitives; no new visual language.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbList from '../components/astro/BreadcrumbList.astro';
import Section from '../components/astro/Section.astro';
import SectionHeading from '../components/astro/SectionHeading.astro';
import DetailSheet from '../components/islands/DetailSheet';
import Changelog from '../components/astro/Changelog.astro';
import { contentRepository, siteConfig } from '../config/site';

const hub = await contentRepository.getEngineeringHub();

const pageTitle = 'Engineering';
const pageDescription =
  'How felipetavares.dev is actually built: the decisions behind it, the stack, and a changelog distilled from real commit history.';
const canonical = `${siteConfig.url}/engineering`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} markdownTwin="/engineering.md">
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: 'Engineering', url: canonical },
  ]} />

  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="engineering-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">Engineering</p>
      <h1 id="engineering-heading" class="text-balance" data-reveal>How this site is actually built</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
        This site itself is a proof point: the decisions behind it, the stack it runs on, and a
        changelog distilled from its real commit history. Not marketing copy about engineering
        discipline. The discipline itself.
      </p>
    </div>
  </section>

  <Section padding="first" aria-labelledby="decisions-heading">
    <h2 id="decisions-heading" class="sr-only">Decisions</h2>
    <SectionHeading
      eyebrow="Decisions"
      title="Six calls that shaped the build"
      subtitle="Context, the call made, and what it cost or bought. Rewritten from this repo's own ADRs and design specs."
    />
    <ul class="mt-10 grid auto-rows-fr grid-cols-1 gap-4 sm:grid-cols-2">
      {
        hub.decisions.map((item) => (
          <li data-card-motion class="glass flex h-full flex-col justify-between rounded-[var(--radius-md)] p-6">
            <div>
              <h3 class="font-display text-lg font-semibold text-[var(--text)]">{item.title}</h3>
              <p class="mt-3 text-sm text-muted">{item.context}</p>
              <p class="mt-2 text-sm text-[var(--text)]">{item.decision}</p>
            </div>
            <div class="mt-4">
              <DetailSheet client:visible triggerLabel="What it cost/bought →" title={item.title}>
                <p>{item.cost}</p>
              </DetailSheet>
            </div>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section aria-labelledby="stack-heading">
    <h2 id="stack-heading" class="sr-only">Why this stack</h2>
    <SectionHeading
      eyebrow="Why this stack"
      title="Every piece, one honest reason"
      subtitle="No component here is the default choice. Each earned its place against the $0/month constraint."
    />
    <ul class="mt-10 grid grid-cols-1 gap-3 sm:grid-cols-2">
      {
        hub.stack.map((item) => (
          <li class="glass flex flex-col gap-1 rounded-[var(--radius-md)] p-5">
            <p class="font-mono text-sm font-semibold text-[var(--text)]">{item.name}</p>
            <p class="text-sm text-muted">{item.reason}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section aria-labelledby="changelog-heading" padding="default">
    <h2 id="changelog-heading" class="sr-only">Changelog</h2>
    <SectionHeading
      eyebrow="Changelog"
      title="Milestones, not commit noise"
      subtitle="Distilled from real git history: dated, narrative, no hashes to chase."
    />
    <div class="mt-10">
      <Changelog entries={hub.changelog} collapseAfter={5} />
    </div>
  </Section>
</BaseLayout>
