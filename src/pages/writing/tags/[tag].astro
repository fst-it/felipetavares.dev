---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbList from '../../../components/astro/BreadcrumbList.astro';
import { contentRepository, siteConfig } from '../../../config/site';
import { slugifyTag } from '../../../lib/slugify-tag';

export async function getStaticPaths() {
  const articles = await contentRepository.getArticles();
  const tags = [...new Set(articles.flatMap((a) => a.tags))];
  return tags.map((tag) => ({ params: { tag: slugifyTag(tag) }, props: { tag } }));
}

const { tag } = Astro.props as { tag: string };
const allArticles = await contentRepository.getArticles();
const articles = allArticles.filter((a) => a.tags.some((t) => slugifyTag(t) === Astro.params.tag));

const dateFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const pageTitle = `${tag}: Writing`;
const pageDescription = `Articles tagged "${tag}" by Felipe Tavares on enterprise architecture, AI strategy, and data platforms.`;
const canonical = `${siteConfig.url}/writing/tags/${Astro.params.tag}`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: 'Writing', url: `${siteConfig.url}/writing` },
    { name: tag, url: canonical },
  ]} />
  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="tag-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <nav aria-label="Breadcrumb" class="text-sm text-muted">
        <a href="/writing" class="hover:text-[var(--accent)]">Writing</a>
        <span aria-hidden="true"> / </span>
        <span>{tag}</span>
      </nav>
      <p class="mb-2 mt-4 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">Tag</p>
      <h1 id="tag-heading" class="text-balance">{tag}</h1>
    </div>
  </section>

  <section class="px-4 pb-11 sm:pb-16">
    <div class="mx-auto grid auto-rows-fr max-w-6xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        articles.map((article) => (
          <a
            href={`/writing/${article.slug}`}
            class="glass flex h-full flex-col justify-between rounded-[var(--radius-md)] p-6 transition-transform duration-200 hover:-translate-y-1"
          >
            <div>
              <h2 class="font-display text-lg font-semibold text-[var(--text)]">{article.title}</h2>
              <p class="mt-2 text-sm text-muted">{article.description}</p>
            </div>
            <div class="mt-6 flex flex-wrap items-center gap-2 font-mono text-xs text-muted">
              <span>{dateFormatter.format(article.pubDate)}</span>
              <span aria-hidden="true">·</span>
              <span>{article.readingTime}</span>
            </div>
          </a>
        ))
      }
    </div>

    <p class="mx-auto mt-10 max-w-6xl text-sm text-muted">
      <a href="/writing" class="text-[var(--accent)] underline underline-offset-2">&larr; All writing</a>
    </p>
  </section>
</BaseLayout>
