---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoleChapter from '../../components/astro/RoleChapter.astro';
import JourneyProgressRail from '../../components/astro/JourneyProgressRail.astro';
import JourneyPathLine from '../../components/astro/JourneyPathLine.astro';
import BreadcrumbList from '../../components/astro/BreadcrumbList.astro';
import ExperienceViewToggle from '../../components/islands/ExperienceViewToggle';
import CountryFlag from '../../components/astro/CountryFlag.astro';
import { contentRepository, siteConfig } from '../../config/site';
import { getStrings } from '../../i18n';
import { formatMonthYear } from '../../lib/format-date';
import { countryCodeForLocation } from '../../lib/location-to-flag';

// Only the quiet stewardship line below reads from the dictionary (spec: single source of truth
// for that EN/PT-shared sentence) — the rest of this page's copy stays hardcoded EN, matching its
// existing style; the PT sibling (pt/experience/index.astro) already uses getStrings for
// everything.
const strings = getStrings('en');

const positioning = await contentRepository.getPositioning();
// getRoles() returns reverse-chronological (current role first, order ascending from most
// recent) — V5a fix 3a: the Journey page now keeps that order (current role on top) per the
// owner's explicit "latest-first" direction, rather than the previous `.reverse()` into
// earliest-first chronological order.
const roles = await contentRepository.getRoles();

const pageTitle = 'Journey';
const pageDescription =
  "Felipe Tavares' career story: 18 years turning complex trade and operational processes into enterprise architecture, AI, and data strategy that ships.";

// ProfilePage JSON-LD — signals to Google that this page is about a real person's career.
const profilePageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: pageTitle,
  url: `${siteConfig.url}/experience`,
  mainEntity: {
    '@type': 'Person',
    name: siteConfig.name,
    url: siteConfig.url,
    jobTitle: 'Senior Principal Architect Leader',
  },
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={`${siteConfig.url}/experience`} markdownTwin="/experience/index.md">
  <script type="application/ld+json" set:html={JSON.stringify(profilePageJsonLd)} is:inline />
  <BreadcrumbList crumbs={[
    { name: 'Home', url: siteConfig.url },
    { name: 'Journey', url: `${siteConfig.url}/experience` },
  ]} />
  <JourneyProgressRail roles={roles} />

  <section class="relative overflow-hidden px-4 pb-11 pt-11 sm:pt-16" aria-labelledby="journey-heading">
    <div class="gradient-mesh" aria-hidden="true">
      <div class="mesh-blob"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl text-center">
      <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">Journey</p>
      <h1 id="journey-heading" class="text-balance" data-reveal>The story behind the architecture</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">{positioning.statement}</p>
    </div>
  </section>

  <div class="px-4 pb-4">
    <div class="mx-auto max-w-4xl">
      <ExperienceViewToggle
        client:load
        label={strings.journey.chaptersHeading}
        summaryLabel={strings.journey.viewSummary}
        detailedLabel={strings.journey.viewDetailed}
        sectionId="experience-chapters"
      />
    </div>
  </div>

  <section id="experience-chapters" data-experience-view="summary" class="relative px-4 pb-11 sm:pb-16" aria-labelledby="chapters-heading">
    <h2 id="chapters-heading" class="sr-only">Role chapters</h2>

    {/* Detailed view — current full chapter cards (shown when data-experience-view="detailed") */}
    <div class="experience-detailed relative mx-auto max-w-4xl">
      <JourneyPathLine />
      <ol class="relative z-[1] flex flex-col gap-10 pl-6 sm:gap-16 sm:pl-8">
        {roles.map((role, i) => <RoleChapter role={role} index={i} />)}
      </ol>
    </div>

    {/* Summary view — compact single-card-per-role (shown when data-experience-view="summary") */}
    <div class="experience-summary mx-auto max-w-4xl">
      <ol class="flex flex-col gap-3">
        {roles.map((role) => {
          const flagCountry = countryCodeForLocation(role.location);
          const additionalFlagCountry = role.additionalLocation ? countryCodeForLocation(role.additionalLocation) : null;
          const period = `${formatMonthYear(role.start, 'en')} — ${role.end ? formatMonthYear(role.end, 'en') : strings.journey.present}`;
          return (
            <li class="glass rounded-[var(--radius-md)] p-5">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <div>
                  <p class="font-mono text-xs uppercase tracking-wider text-[var(--accent)]">{period}</p>
                  <p class="mt-1 font-display text-base font-semibold text-[var(--text)]">{role.title} · {role.org}</p>
                </div>
                {role.additionalLocation ? (
                  <div class="flex flex-col gap-0.5 text-sm text-muted">
                    <span class="flex items-center gap-1.5">
                      {flagCountry && <CountryFlag country={flagCountry} uniqueKey={`sum-${role.slug}`} class="rounded-full" />}
                      {role.location}
                    </span>
                    <span class="flex items-center gap-1.5">
                      {additionalFlagCountry && <CountryFlag country={additionalFlagCountry} uniqueKey={`sum2-${role.slug}`} class="rounded-full" />}
                      {role.additionalLocation}
                    </span>
                  </div>
                ) : (
                  <p class="flex items-center gap-1.5 text-sm text-muted">
                    {flagCountry && <CountryFlag country={flagCountry} uniqueKey={`sum-${role.slug}`} class="rounded-full" />}
                    {role.location}
                  </p>
                )}
              </div>
              <p class="mt-2 text-sm text-[var(--accent-2)]">{role.arc}</p>
              {role.domains.length > 0 && (
                <ul class="mt-3 flex flex-wrap gap-1.5">
                  {role.domains.map((domain) => (
                    <li class="rounded-full bg-[var(--surface-glass-strong)] px-2.5 py-1 text-xs text-muted">
                      {domain}
                    </li>
                  ))}
                </ul>
              )}
            </li>
          );
        })}
      </ol>
    </div>
  </section>

</BaseLayout>

<style>
  /*
   * Experience view toggle (item 11, 2026-07-06 refinement). Both variants are SSR'd into the
   * HTML; only one is visible at a time, driven by data-experience-view on #experience-chapters.
   * Default is "summary" (the attribute's SSR value), so the page is always meaningful without JS.
   * Using display:none (not visibility:hidden) so hidden content is skipped by screen readers too.
   */
  #experience-chapters[data-experience-view='detailed'] .experience-summary {
    display: none;
  }
  #experience-chapters[data-experience-view='summary'] .experience-detailed {
    display: none;
  }
  /* Fallback: if the attribute is missing (e.g. JS injected it before CSS loaded), show summary. */
  #experience-chapters:not([data-experience-view]) .experience-detailed {
    display: none;
  }
</style>
