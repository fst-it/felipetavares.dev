---
import { contentRepository } from '../../config/site';
import SectionHeading from './SectionHeading.astro';
import { resolveLocale, getStrings } from '../../i18n';

const locale = resolveLocale(Astro.currentLocale);
const strings = getStrings(locale);
const projects = await contentRepository.getFeaturedProjects();

const statusLabel: Record<string, string> = {
  active: strings.home.statusActive,
  archived: strings.home.statusArchived,
  incubating: strings.home.statusIncubating,
};
---

<section class="px-4 py-11 sm:py-16" aria-labelledby="projects-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="projects-heading" class="sr-only">Featured projects</h2>
    <SectionHeading
      eyebrow={strings.home.projectsEyebrow}
      title={strings.home.projectsTitle}
      subtitle={strings.home.projectsSubtitle}
    />

    {
      projects.length > 0 ? (
        <!--
          Equal-height bento cells (V3-polish commit 4): the previous `i === 0 ? 'lg:col-span-2
          lg:row-span-2' : ''` made the first featured project (Selfwright) span 2 columns AND 2
          rows, dwarfing every other card (felipetavares.dev rendered tiny by comparison) —
          removed entirely so every card gets the same footprint; auto-rows-fr + h-full keeps them
          equal height regardless of content length, tagline-only on every card (no special-cased
          "lead" card).

          On PT routes (V3d addendum), project deep-dives stay EN-only in v1 — cards here still
          link to the unprefixed EN project page and show a small "em inglês" badge next to the
          status tag, rather than duplicating this content into PT.

          V5a fix 8: the title+badge header row had no `flex-wrap` — on PT specifically, the extra
          "em inglês" badge next to the status pill pushed this row's minimum content width past
          320px (title + both badges never wrapping), causing a real horizontal-overflow bug on
          this page at 320px. Added `flex-wrap` to both the outer row and the badge group.
        -->
        <div class="mt-10 grid auto-rows-fr grid-cols-1 gap-4 lg:grid-cols-3">
          {projects.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              data-card-motion
              class="glass group flex h-full flex-col justify-between rounded-[var(--radius-md)] p-6 transition-transform duration-200 hover:-translate-y-1"
            >
              <div>
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <h3 class="font-display text-xl font-semibold text-[var(--text)]">{project.title}</h3>
                  <div class="flex flex-wrap items-center gap-2">
                    {locale === 'pt-br' && (
                      <span class="rounded-full bg-[var(--surface-glass-strong)] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-muted">
                        {strings.home.inEnglishBadge}
                      </span>
                    )}
                    <span class="font-mono text-xs uppercase tracking-wide text-[var(--accent)]">
                      {statusLabel[project.status]}
                    </span>
                  </div>
                </div>
                <p class="mt-2 text-sm text-muted">{project.tagline}</p>
              </div>

              <p class="mt-6 text-xs font-medium text-[var(--accent)]">{strings.home.readDeepDive}</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-10 text-muted">{strings.home.projectsEmpty}</p>
      )
    }
  </div>
</section>
