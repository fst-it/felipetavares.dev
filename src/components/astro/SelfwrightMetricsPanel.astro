---
/**
 * "Measured, not claimed" panel (build stage: "Selfwright eval surface") — renders the curated
 * snapshot at `content/metrics/selfwright.json` as branded stat-tiles, reusing the credibility-
 * tile idiom from CredibilityCta.astro (uppercase mono eyebrow, thread underline, glass +
 * tile-glow hover, staggered reveal-on-scroll — same visual language, its own scoped copy per
 * Astro's per-component style scoping, same documented pattern as CredibilityCta/JourneyProgressRail/
 * RoleChapter's three independent copies of this exact reveal treatment, docs/architecture.md
 * finding #11).
 *
 * Renders nothing if the snapshot is missing (`contentRepository.getSelfwrightMetrics()` returns
 * `undefined` when `content/metrics/selfwright.json` hasn't been generated yet — the owner runs
 * `pnpm import-selfwright-metrics` manually; no CI coupling, per the stage's own decision).
 */
import { contentRepository } from '../../config/site';
import { formatCardDate } from '../../lib/format-date';

const snapshot = await contentRepository.getSelfwrightMetrics();
// capturedAt is a plain "YYYY-MM-DD" string (schema-enforced) — parse to a Date so
// formatCardDate (the existing "Jul 5, 2026" formatter) can render it, rather than adding a
// fourth date-formatting variant for the same display weight (ADR 0002: single source of truth).
const capturedAtDate = snapshot ? new Date(`${snapshot.capturedAt}T00:00:00`) : null;

function toOrdinalTag(i: number): string {
  return String(i + 1).padStart(2, '0');
}
---

{
  snapshot && (
    <div class="selfwright-metrics-panel">
      <h2 class="font-display text-xl">Measured, not claimed</h2>
      <p class="mt-2 text-sm text-muted">
        Pulled from Selfwright's own eval suite, fitness functions, and acceptance-test docs — a snapshot,
        curated {capturedAtDate && formatCardDate(capturedAtDate)}. Refreshed by hand when it changes, not on every commit.
      </p>

      <div class="mt-6 grid auto-rows-fr grid-cols-1 gap-4 sm:grid-cols-2">
        {snapshot.groups.map((group, i) => (
          <div class="selfwright-tile tile-glow glass flex h-full flex-col rounded-[var(--radius-md)] p-6" style={`--tile-index: ${i}`}>
            <p class="font-mono text-xs uppercase tracking-wider text-[var(--accent)]">{toOrdinalTag(i)}</p>
            <span class="selfwright-tile-underline mt-2" aria-hidden="true" />
            <p class="mt-4 font-display text-base font-semibold text-[var(--text)]">{group.title}</p>
            <dl class="mt-3 flex flex-col gap-2">
              {group.metrics.map((metric) => (
                <div>
                  <dt class="text-xs text-muted">{metric.label}</dt>
                  <dd class="mt-0.5 font-mono text-sm font-semibold text-[var(--text)]">{metric.value}</dd>
                </div>
              ))}
            </dl>
            <p class="mt-4 text-xs text-muted">{group.source}</p>
          </div>
        ))}
      </div>
    </div>
  )
}

<style>
  .selfwright-tile-underline {
    display: block;
    width: 2rem;
    height: 2px;
    border-radius: 2px;
    background: var(--accent);
    box-shadow: 0 0 6px 0 var(--accent-glow);
  }

  /* Non-interactive glow-on-hover — same treatment as CredibilityCta.astro's `.tile-glow`. */
  .tile-glow {
    transition: box-shadow var(--duration-micro, 200ms) var(--ease-out, ease-out);
  }

  @media (hover: hover) {
    .tile-glow:hover {
      box-shadow: 0 4px 20px -6px var(--accent-glow);
    }
  }

  /* Staggered reveal-on-scroll — same pattern as CredibilityCta.astro/RoleChapter.astro/
   * JourneyProgressRail.astro (docs/architecture.md finding #11: kept as a documented variant,
   * not extracted — see this file's top-of-file comment). */
  .selfwright-tile {
    opacity: 1;
  }

  @supports (animation-timeline: view()) {
    .selfwright-tile {
      animation: selfwright-tile-reveal linear both;
      animation-timeline: view();
      animation-range: entry 0% cover 25%;
      animation-delay: calc(var(--tile-index, 0) * 80ms);
    }
  }

  @supports not (animation-timeline: view()) {
    .selfwright-tile {
      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity var(--duration-reveal) var(--ease-out),
        transform var(--duration-reveal) var(--ease-out);
      transition-delay: calc(var(--tile-index, 0) * 80ms);
    }

    .selfwright-tile.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes selfwright-tile-reveal {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .selfwright-tile {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  html[data-motion='off'] .selfwright-tile {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
</style>

<script>
  // IntersectionObserver fallback for browsers without `animation-timeline: view()` support —
  // same pattern as CredibilityCta.astro/JourneyProgressRail.astro.
  const tiles = Array.from(document.querySelectorAll<HTMLElement>('.selfwright-tile'));
  if ('IntersectionObserver' in window && tiles.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      },
      { threshold: 0.2 }
    );
    tiles.forEach((tile) => observer.observe(tile));
  } else {
    tiles.forEach((tile) => tile.classList.add('is-visible'));
  }
</script>
