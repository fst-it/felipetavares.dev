---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, align = 'left' } = Astro.props;
---

<div class={`max-w-2xl ${align === 'center' ? 'mx-auto text-center' : ''}`}>
  {eyebrow && (
    <p class="mb-2 font-mono text-sm uppercase tracking-wider text-[var(--accent)]">{eyebrow}</p>
  )}
  <h2 data-reveal>{title}</h2>
  {subtitle && <p class="mt-3 text-muted">{subtitle}</p>}
</div>
