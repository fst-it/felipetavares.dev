---
import { localizedNav } from '../../config/nav';
import { siteConfig, contentRepository } from '../../config/site';
import { resolveLocale, getStrings, localeToPathPrefix } from '../../i18n';
import BrandMark from './BrandMark.astro';
import SocialIcon from './SocialIcon.astro';
import SubstackEmbed from './SubstackEmbed.astro';

const socialLinks = await contentRepository.getSocialLinks();
const year = new Date().getFullYear();

const locale = resolveLocale(Astro.currentLocale);
const strings = getStrings(locale);
const prefix = localeToPathPrefix(locale);
const nav = localizedNav(strings);
---

<!--
  Compact two-row footer band (V3-polish commit 4) — roughly half the previous height (a 3-column
  flex-col-on-mobile block plus a second stacked row, vs. two tight rows here). Row 1: monogram +
  name (left) · nav links inline (center) · socials (right). Row 2: copyright · Accessibility/
  Privacy links · compact newsletter link. All interactive targets stay >=44px
  (`min-h-11`/`h-11 w-11`); wraps cleanly at narrow widths via flex-wrap.
-->
<footer class="mt-24 px-4 pb-8">
  <div class="glass mx-auto flex max-w-6xl flex-col gap-3 px-6 py-5 sm:px-8">
    <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3">
      <a href={prefix ? `${prefix}/` : '/'} class="inline-flex min-h-11 items-center gap-2 text-sm font-semibold text-[var(--text)]">
        <BrandMark size={22} class="text-[var(--accent)]" />
        {siteConfig.name}
      </a>

      <nav aria-label="Footer" class="flex flex-wrap items-center gap-x-5 gap-y-2">
        {
          nav.map((link) => (
            <a
              href={`${prefix}${link.href}`}
              class="inline-flex min-h-11 items-center text-sm font-medium text-muted transition-colors duration-200 hover:text-[var(--text)]"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="flex flex-wrap items-center gap-3">
        {
          socialLinks.map((link) => (
            <a
              href={link.url}
              aria-label={link.label}
              class="inline-flex h-11 w-11 items-center justify-center text-muted transition-colors duration-200 hover:text-[var(--accent)]"
              target="_blank"
              rel="noopener noreferrer me"
            >
              <SocialIcon icon={link.icon as 'github' | 'linkedin' | 'rss'} />
            </a>
          ))
        }
        <SubstackEmbed variant="compact" />
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-1 border-t border-[var(--border-glass)] pt-2">
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
        <a
          href={`${prefix}/accessibility`}
          class="inline-flex min-h-11 items-center text-xs font-medium text-muted transition-colors duration-200 hover:text-[var(--text)]"
        >
          {strings.footer.accessibility}
        </a>
        <a
          href={`${prefix}/privacy`}
          class="inline-flex min-h-11 items-center text-xs font-medium text-muted transition-colors duration-200 hover:text-[var(--text)]"
        >
          {strings.footer.privacy}
        </a>
        <!--
          /engineering is a proof-of-work hub, EN-only (no PT translation — same v1 scope decision
          as articles/project deep-dives). Not part of `localizedNav`/the header — deliberately
          kept off the primary nav to stay lean; this footer row (alongside Accessibility/Privacy)
          is its one sitewide entry point besides the felipetavares.dev deep-dive pointer card. On
          PT routes it still links out (unprefixed, to the EN page) carrying the same "em inglês"
          badge PT content cards use elsewhere (see pt/writing/index.astro) rather than being
          hidden or duplicated into a PT-only page.
        -->
        <a
          href="/engineering"
          class="inline-flex min-h-11 items-center gap-1.5 text-xs font-medium text-muted transition-colors duration-200 hover:text-[var(--text)]"
        >
          Engineering
          {locale === 'pt-br' && (
            <span class="rounded-full bg-[var(--surface-glass-strong)] px-1.5 py-0.5 font-mono text-[9px] uppercase tracking-wide text-muted">
              {strings.home.inEnglishBadge}
            </span>
          )}
        </a>
        {/* Reading nav link removed until section is seeded — ledger row 66;
            re-enable when content is live: add <a href={`${prefix}/reading`}> here */}
      </div>

      <p class="text-xs text-muted">{strings.footer.copyright(year, siteConfig.name)}</p>
    </div>
  </div>
</footer>
