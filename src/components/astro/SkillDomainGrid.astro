---
import { contentRepository } from '../../config/site';
import SectionHeading from './SectionHeading.astro';
import { resolveLocale, getStrings } from '../../i18n';

const locale = resolveLocale(Astro.currentLocale);
const strings = getStrings(locale);
const domains = await contentRepository.getSkillDomains(locale);

const EN_WORDS = ['Zero', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine', 'Ten', 'Eleven', 'Twelve'];
const PT_WORDS = ['Zero', 'Uma', 'Duas', 'Três', 'Quatro', 'Cinco', 'Seis', 'Sete', 'Oito', 'Nove', 'Dez', 'Onze', 'Doze'];

function toWords(n: number): string {
  const words = locale === 'pt-br' ? PT_WORDS : EN_WORDS;
  return words[n] ?? String(n);
}
---

<section class="px-4 py-11 sm:py-16" aria-labelledby="skill-domains-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="skill-domains-heading" class="sr-only">Domains of expertise</h2>
    <SectionHeading
      eyebrow={strings.home.domainsEyebrow}
      title={strings.home.domainsTitle}
      subtitle={strings.home.domainsSubtitle(toWords(domains.length))}
    />

    <!--
      Uniform 12-cell grid (V3-polish commit 4): every blurb is now a single ~14-20 word sentence
      (no domain needs the InlineExpander "More" disclosure anymore, so cards are naturally
      equal-length) — 1/2/3/4 columns at mobile/sm/lg/xl, auto-rows-fr + h-full keeps every card
      the same height at every breakpoint regardless of row count (12/6/4/3 rows respectively).
    -->
    <ul class="mt-10 grid auto-rows-fr grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        domains.map((domain) => (
          <li
            data-card-motion
            class="glass group flex h-full flex-col rounded-[var(--radius-md)] p-6 transition-transform duration-200 hover:-translate-y-1 focus-within:-translate-y-1"
            tabindex="0"
          >
            <h3 class="font-display text-lg font-semibold text-[var(--text)]">{domain.name}</h3>
            <p class="mt-3 text-sm text-muted opacity-90 transition-opacity duration-200 group-hover:opacity-100">
              {domain.blurb}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
